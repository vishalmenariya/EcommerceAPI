  "components": {
    "schemas": {
      "Customer": {
        "required": [
          "customerName",
          "customerPhone",
          "customerEmail",
          "customerCountry"
        ],
        "type": "object",
        "properties": {
          "customerId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "customerName": {
            "maxLength": 100,
            "pattern": "^[a-zA-Z\\s]{3,100}$",
            "type": "string"
          },
          "customerPhone": {
            "maxLength": 20,
            "type": "string"
          },
          "customerEmail": {
            "maxLength": 150,
            "type": "string"
          },
          "customerCountry": {
            "maxLength": 50,
            "pattern": "^[a-zA-Z\\s]{3,50}$",
            "type": "string"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "orderId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "orderDate": {
            "type": "string",
